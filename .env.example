# ============================================================
# 环境变量配置说明
# ============================================================
# 在启动服务前，请设置以下环境变量：
# 
# Windows (PowerShell):
#   $env:DB_USERNAME="root"
#   $env:DB_PASSWORD="your_secure_password"
#   $env:JWT_SECRET="your_256_bit_secret_key_at_least_32_chars"
#   $env:REDIS_PASSWORD="your_redis_password"
#
# Linux/Mac:
#   export DB_USERNAME=root
#   export DB_PASSWORD=your_secure_password
#   export JWT_SECRET=your_256_bit_secret_key_at_least_32_chars
#   export REDIS_PASSWORD=your_redis_password
#
# 或者在启动命令中指定：
#   java -jar app.jar --spring.datasource.password=${DB_PASSWORD}
#
# ============================================================
# 安全最佳实践：
# 1. 生产环境不要使用默认密码
# 2. JWT密钥至少256位(32字符)
# 3. 使用配置中心或密钥管理服务
# 4. 敏感信息不要提交到版本控制
# ============================================================

# 数据库配置
DB_USERNAME=root
DB_PASSWORD=your_secure_password_here

# JWT配置 (至少32字符)
JWT_SECRET=your_256_bit_secret_key_at_least_32_characters_long

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Eureka配置
EUREKA_HOST=localhost
EUREKA_PORT=8761

# Spring Boot Admin
ADMIN_HOST=localhost
ADMIN_PORT=8090
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
